# คัดลอกเป็น .env แล้วแก้ค่าก่อน deploy
SECRET_KEY=replace-with-long-random-string
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# หรือหลาย user (รหัสผ่าน plain จะถูก hash ตอนสตาร์ท):
# USERS_JSON={"alice":"secret1","bob":"secret2"}

DOMAIN=localhost
SESSION_COOKIE_SECURE=true
MAX_UPLOAD_MB=16

# บังคับฟอนต์ (ค่าเริ่มต้นใช้ fonts/THSarabunIT๙.ttf)
# FONT_PATH=./fonts/THSarabun.ttf

# ไลเซนต์ (ตั้งค่าเดียวกันตอนออกคีย์ด้วย scripts/gen_license.py)
LICENSE_SECRET=replace-with-long-random-license-secret
# LICENSE_BYPASS=true   # ข้ามตรวจไลเซนต์ตอนพัฒนา

# local dev (ไม่ใช้ Docker):
# HOST=127.0.0.1
# PORT=5000
# DATA_DIR=./data
# SESSION_COOKIE_SECURE=false
