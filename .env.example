# คัดลอกเป็น .env แล้วแก้ค่าก่อน deploy
SECRET_KEY=replace-with-long-random-string

# --- โหมดโรงเรียน (ค่าเริ่มต้นของแอป) ---
# ไม่บังคับ login — ใช้ user ในเครื่องชื่อ local
# AUTH_REQUIRED=false
# LOCAL_USER=local
# HOST=127.0.0.1
# PORT=5000
# SESSION_COOKIE_SECURE=false
#
# บน Windows ค่าเริ่มต้น (ไม่ต้องตั้ง):
#   DATA_DIR = %LOCALAPPDATA%\PDFFormMarker\data
#   LOG_DIR  = %LOCALAPPDATA%\PDFFormMarker\logs
# ถ้ามีโฟลเดอร์ ./data เก่าในโปรเจกต์อยู่แล้ว แอปจะใช้ต่ออัตโนมัติ
# บังคับ path เอง:
# DATA_DIR=./data
# LOG_DIR=./data/logs
#
# เปิดโฟลเดอร์จาก UI: เปิดอัตโนมัติเมื่อ HOST เป็น 127.0.0.1
# บน Docker (HOST=0.0.0.0) ปิดอยู่ — บังคับเปิดด้วย:
# ENABLE_OPEN_FOLDER=true
#
# แยกไฟล์ log ต่อ gunicorn worker (ค่าเริ่มต้น: เปิดเองเมื่อ HOST ไม่ใช่ loopback)
# LOG_PER_WORKER=true
#
# เชื่อ X-Forwarded-For สำหรับ rate-limit client-log (เปิดใน Docker หลัง Caddy)
# TRUST_X_FORWARDED_FOR=true

# --- โหมดหลายผู้ใช้ / Docker (Advanced) ---
# AUTH_REQUIRED=true
ADMIN_USER=admin
ADMIN_PASSWORD=changeme
# หรือหลาย user (รหัสผ่าน plain จะถูก hash ตอนสตาร์ท):
# USERS_JSON={"alice":"secret1","bob":"secret2"}

DOMAIN=localhost
SESSION_COOKIE_SECURE=true
MAX_UPLOAD_MB=16

# บังคับฟอนต์ (ค่าเริ่มต้นใช้ fonts/THSarabunIT๙.ttf)
# FONT_PATH=./fonts/THSarabun.ttf

# ไลเซนต์: แอปลูกค้าใช้แค่ license_public.pem (มากับโค้ด)
# ฝั่งผู้ขายเก็บ keys/ed25519_private.pem ไว้เครื่องตัวเองเท่านั้น
# path ด้านล่าง relative กับ cwd ตอนรันสคริปต์ — หรือใส่ absolute path
# LICENSE_PRIVATE_KEY_PATH=keys/ed25519_private.pem
# LICENSE_PUBLIC_KEY_PATH=license_public.pem
# LICENSE_BYPASS=true   # ข้ามตรวจไลเซนต์ตอนพัฒนา — ห้ามเปิดบนเครื่องลูกค้า
