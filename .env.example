# คัดลอกเป็น .env แล้วแก้ค่าก่อน deploy
SECRET_KEY=replace-with-long-random-string
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# หรือหลาย user (รหัสผ่าน plain จะถูก hash ตอนสตาร์ท):
# USERS_JSON={"alice":"secret1","bob":"secret2"}

DOMAIN=localhost
SESSION_COOKIE_SECURE=true
MAX_UPLOAD_MB=16

# local dev (ไม่ใช้ Docker):
# HOST=127.0.0.1
# PORT=5000
# DATA_DIR=./data
# SESSION_COOKIE_SECURE=false
