# คัดลอกเป็น .env แล้วแก้ค่าก่อน deploy
SECRET_KEY=replace-with-long-random-string
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# หรือหลาย user (รหัสผ่าน plain จะถูก hash ตอนสตาร์ท):
# USERS_JSON={"alice":"secret1","bob":"secret2"}

DOMAIN=localhost
SESSION_COOKIE_SECURE=true
MAX_UPLOAD_MB=16

# บังคับฟอนต์ (ค่าเริ่มต้นใช้ fonts/THSarabunIT๙.ttf)
# FONT_PATH=./fonts/THSarabun.ttf

# ไลเซนต์: แอปลูกค้าใช้แค่ license_public.pem (มากับโค้ด)
# ฝั่งผู้ขายเก็บ keys/ed25519_private.pem ไว้เครื่องตัวเองเท่านั้น
# path ด้านล่าง relative กับ cwd ตอนรันสคริปต์ — หรือใส่ absolute path
# LICENSE_PRIVATE_KEY_PATH=keys/ed25519_private.pem
# LICENSE_PUBLIC_KEY_PATH=license_public.pem
# LICENSE_BYPASS=true   # ข้ามตรวจไลเซนต์ตอนพัฒนา — ห้ามเปิดบนเครื่องลูกค้า

# local dev (ไม่ใช้ Docker):
# HOST=127.0.0.1
# PORT=5000
# DATA_DIR=./data
# SESSION_COOKIE_SECURE=false
